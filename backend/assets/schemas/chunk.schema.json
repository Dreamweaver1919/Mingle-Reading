{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingle-reading.local/backend/assets/schemas/chunk.schema.json",
  "title": "Mingle Reading Retrieval Chunk",
  "type": "object",
  "required": [
    "chunk_id",
    "book_id",
    "chapter_id",
    "chunk_level",
    "text",
    "position",
    "spoiler_guard",
    "tags"
  ],
  "properties": {
    "chunk_id": { "type": "string" },
    "book_id": { "type": "string" },
    "chapter_id": { "type": "string" },
    "section_id": { "type": ["string", "null"] },
    "paragraph_start_id": { "type": ["string", "null"] },
    "paragraph_end_id": { "type": ["string", "null"] },
    "chunk_level": {
      "type": "string",
      "enum": ["l0_raw_paragraph", "l1_fine_grained", "l2_structure_summary", "l3_global_index", "l4_quote_or_stance"]
    },
    "text": { "type": "string" },
    "position": {
      "type": "object",
      "required": ["chapter_index", "section_index", "char_start", "char_end"],
      "properties": {
        "chapter_index": { "type": "integer", "minimum": 0 },
        "section_index": { "type": "integer", "minimum": 0 },
        "char_start": { "type": "integer", "minimum": 0 },
        "char_end": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "characters_present": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "salience": {
      "type": "object",
      "properties": {
        "emotion_intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "conflict_intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "psychological_complexity": { "type": "number", "minimum": 0, "maximum": 1 },
        "symbolic_density": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "spoiler_guard": {
      "type": "object",
      "required": ["spoiler_level", "max_visible_chapter_index"],
      "properties": {
        "spoiler_level": { "type": "string", "enum": ["safe", "mild", "high"] },
        "max_visible_chapter_index": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "source_record_id": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
